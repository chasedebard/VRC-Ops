# Supabase project connection for VRC Ops web.
# These are the same values used by the RFS Race Control apps' "publishable"
# (anon) key — safe for a public client because every table is protected by
# Row Level Security. NEVER put a service-role/secret key in this app.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Base URL this app is deployed at, used to build invite links consistently
# with the Supabase "send-league-invite" edge function's RFS_APP_BASE_URL.
VITE_APP_BASE_URL=https://vrc-ops.org
